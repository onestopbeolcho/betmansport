rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 공통 헬퍼 ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Users 컬렉션 ───
    match /users/{userId} {
      // 본인 정보 읽기 허용
      allow read: if isOwner(userId) || isAdmin();
      // 본인 정보 수정 (tier, role 등 민감 필드는 서버에서만 변경)
      allow update: if isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'tier', 'subscription_plan', 'subscription_expires_at']);
      // 생성은 인증된 사용자만
      allow create: if isAuthenticated();
      // 삭제는 관리자만
      allow delete: if isAdmin();
    }

    // ─── Payments 컬렉션 (결제 기록) ───
    match /payments/{paymentId} {
      // 본인 결제 내역만 읽기
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      // 생성/수정/삭제는 서버(Admin SDK)에서만
      allow write: if false;
    }

    // ─── Portfolio 컬렉션 ───
    match /portfolio/{itemId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // ─── Community (투표/커뮤니티) ───
    match /votes/{voteId} {
      allow read: if true;  // 투표 결과는 공개
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.user_id);
    }

    match /predictions/{predId} {
      allow read: if true;  // 예측은 공개
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.user_id) || isAdmin();
    }

    // ─── Notifications ───
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow write: if false;  // 서버에서만 생성
    }

    // ─── 기본: 모든 것 차단 ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
